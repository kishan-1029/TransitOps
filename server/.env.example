# Neon Postgres (app runtime uses Prisma + pg driver adapter)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connect_timeout=30"
# Used by prisma migrate / db push
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connect_timeout=30"
JWT_SECRET="transitops-hackathon-secret"
PORT=5000
CLIENT_ORIGIN="http://localhost:5173"
LOCKOUT_MINUTES=15
