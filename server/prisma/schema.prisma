generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DRIVER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  Van
  Truck
  Mini
}

enum VehicleStatus {
  Available
  OnTrip
  InShop
  Retired
}

enum DriverStatus {
  Available
  OnTrip
  OffDuty
  Suspended
}

enum TripStatus {
  Draft
  Dispatched
  Completed
  Cancelled
}

enum MaintenanceStatus {
  Active
  Completed
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  role                 Role
  failedLoginAttempts  Int       @default(0)
  locked               Boolean   @default(false)
  lockedUntil          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tripsCreated         Trip[]    @relation("TripCreator")
}

model Vehicle {
  id              String            @id @default(cuid())
  regNo           String            @unique
  name            String
  type            VehicleType
  capacityKg      Float
  odometer        Int               @default(0)
  acquisitionCost Float
  status          VehicleStatus     @default(Available)
  region          String            @default("Gujarat")
  revenue         Float             @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id               String       @id @default(cuid())
  name             String
  licenseNo        String       @unique
  licenseCategory  String
  licenseExpiry    DateTime
  contact          String
  safetyScore      Float        @default(85)
  tripCompletion   Float        @default(90)
  status           DriverStatus @default(Available)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  trips            Trip[]
}

model Trip {
  id              String     @id @default(cuid())
  tripCode        String     @unique
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  status          TripStatus @default(Draft)
  etaMinutes      Int?
  finalOdometer   Int?
  fuelConsumed    Float?
  cancelReason    String?
  vehicleId       String
  driverId        String
  createdById     String?
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  driver          Driver     @relation(fields: [driverId], references: [id])
  createdBy       User?      @relation("TripCreator", fields: [createdById], references: [id])
  expenses        Expense[]
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String
  serviceType String
  cost        Float
  date        DateTime          @default(now())
  status      MaintenanceStatus @default(Active)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  date      DateTime @default(now())
  liters    Float
  cost      Float
  tripId    String?
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id               String   @id @default(cuid())
  tripId           String?
  vehicleId        String
  toll             Float    @default(0)
  other            Float    @default(0)
  maintenanceLinked Float   @default(0)
  createdAt        DateTime @default(now())
  trip             Trip?    @relation(fields: [tripId], references: [id])
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Setting {
  id           String @id @default("default")
  depotName    String @default("Gandhinagar Depot GJ4")
  currency     String @default("INR (Rs)")
  distanceUnit String @default("Kilometers")
}
